@startuml
!theme plain
skinparam backgroundColor #0d1117
skinparam component {
  BackgroundColor #161b22
  BorderColor #30363d
  FontColor #c9d1d9
  FontSize 11
}
skinparam arrow {
  Color #58a6ff
  FontColor #8b949e
  FontSize 10
}
skinparam rectangle {
  BackgroundColor #0d1117
  BorderColor #30363d
  FontColor #c9d1d9
}
skinparam package {
  BackgroundColor #161b22
  BorderColor #30363d
  FontColor #8b949e
  Padding 8
}
skinparam node {
  BackgroundColor #21262d
  BorderColor #30363d
  FontColor #c9d1d9
}
skinparam note {
  BackgroundColor #1c2128
  BorderColor #30363d
  FontColor #8b949e
}
skinparam packageTitleAlignment left
skinparam defaultTextAlignment center

title <color:#c9d1d9><size:14>**csv-to-parquet — Architecture**</size></color>
legend right
  <color:#8b949e><size:9>Rust · Arrow · Rayon</size></color>
endlegend

' === Force vertical stacking within packages ===
' Use [hidden] arrows to create columns

package "CLI" as cli #21262D {
  [main] as main
  [tui] as tui
  [inspect] as inspect
  main -[hidden]-> tui
  tui -[hidden]-> inspect
}

package "Core" as conv #21262D {
  [mod] as orchestrator
  [csv_blocks] as block_producer
  [pipeline] as pipeline
  [writer] as writer
  [ticker] as ticker
  [counter] as counter
  orchestrator -[hidden]-> block_producer
  block_producer -[hidden]-> pipeline
  pipeline -[hidden]-> writer
  writer -[hidden]-> ticker
  ticker -[hidden]-> counter
}

package "Input" as input #21262D {
  [utils] as utils
  [json] as json_flat
  [json_arrow] as json_nested
  [xlsx] as xlsx
  utils -[hidden]-> json_flat
  json_flat -[hidden]-> json_nested
  json_nested -[hidden]-> xlsx
}

package "Schema" as analysis #21262D {
  [schema] as schema
  [analysis] as ad
  [types] as types
  [builders] as builders
  [conversions] as convs
  schema -[hidden]-> ad
  ad -[hidden]-> types
  types -[hidden]-> builders
  builders -[hidden]-> convs
}

package "Export" as export #21262D {
  [export] as ed
  [to_csv] as to_csv
  [to_json] as to_json
  [to_jsonl] as to_jsonl
  [to_xlsx] as to_xlsx
  ed -[hidden]-> to_csv
  to_csv -[hidden]-> to_json
  to_json -[hidden]-> to_jsonl
  to_jsonl -[hidden]-> to_xlsx
}

' === relationships ===

main --> orchestrator : "dispatch"
main --> tui : "interactive"
main --> inspect : "--view-schema"

orchestrator --> block_producer : "blocks"
orchestrator --> pipeline : "analyze"
orchestrator --> writer : "write"
orchestrator --> ticker : "progress"
orchestrator --> counter : "validate"

orchestrator --> schema : "infer type"
pipeline --> ad : "per-col"

block_producer --> utils
block_producer --> json_flat
block_producer --> json_nested
block_producer --> xlsx

main --> ed : "--to-*"
ed --> to_csv
ed --> to_json
ed --> to_jsonl
ed --> to_xlsx

@enduml
