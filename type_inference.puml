@startuml
!theme plain
skinparam backgroundColor #0d1117
skinparam state {
  BackgroundColor #21262d
  BorderColor #30363d
  FontColor #c9d1d9
}
skinparam arrow {
  Color #58a6ff
  FontColor #8b949e
}
skinparam note {
  BackgroundColor #1c2128
  BorderColor #30363d
  FontColor #8b949e
}

title <color:#c9d1d9><size:18>**Type Inference — Gradual Narrowing Cascade**</size></color>

state start as "__START__" #0d1117
state Boolean #1f6feb
state Int64 #3fb950
state UInt64 #d29922
state Float64 #d2a8ff
state Date32 #f78166
state Timestamp #79c0ff
state LargeUtf8 #f85149

start --> Boolean : sample 10K rows\nper column
Boolean --> Int64 : value does NOT match\nBoolean patterns
Int64 --> UInt64 : negative value OR\nbeyond i64 range
UInt64 --> Float64 : contains '.', 'e', 'E'\nor beyond u64 range
Float64 --> Date32 : recognized as\nvalid date pattern
Date32 --> Timestamp : recognized as\nRFC3339 / datetime\nwith time component
Timestamp --> LargeUtf8 : not parseable\nby any prior type

note right of Boolean
  <color:#c9d1d9>Matches: true/false,
  yes/no, y/n, on/off,
  t/f, 0/1</color>
end note

note right of Date32
  <color:#c9d1d9>Formats:
  YYYY-MM-DD
  DD/MM/YYYY
  MM/DD/YYYY</color>
end note

note right of Timestamp
  <color:#c9d1d9>RFC3339, ISO8601
  YYYY-MM-DD HH:MM:SS
  with fraction/zone</color>
end note

note right of LargeUtf8
  <color:#f85149>Fallback — preserves
  all original values
  as strings</color>
end note

note left of start
  <color:#8b949e>95% confidence threshold
  for final type selection
  (--full-schema-inference
  scans ALL rows)</color>
end note

@enduml
